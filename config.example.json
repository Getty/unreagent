{
  // ============================================================
  //  unreagent — Beispiel-Konfiguration
  //  Kopiere diese Datei nach "config.json" (neben unreagent.exe)
  //  und passe die Pfade an. Forward-Slashes sind unter Windows ok.
  //  Ganze Kommentarzeilen (// oder #) sind erlaubt.
  // ============================================================

  "unreal": {
    "editor": "C:/Program Files/Epic Games/UE_5.7/Engine/Binaries/Win64/UnrealEditor.exe",
    "project": "C:/Projects/MyGame/MyGame.uproject",
    // Zusätzliche Editor-Argumente (das .uproject wird automatisch vorangestellt):
    "args": ["-stdout", "-FullStdOutLogOutput", "-nosplash"],
    "manualStart": false,
    "restart": "on-failure",
    "maxRestarts": 5,
    "restartDelaySeconds": 3
  },

  "agent": {
    "enabled": true,
    "command": "claude",
    // Eigene Agent-Argumente; bei claudeIntegration werden --mcp-config und
    // (falls permissions.enabled) --permission-prompt-tool automatisch ergänzt.
    "args": [],
    "workdir": "",
    "startDelaySeconds": 8,
    "restart": "on-failure",
    "maxRestarts": 10,
    "restartDelaySeconds": 3,
    "claudeIntegration": true
  },

  // Einmal-Befehle, die der Agent über das MCP-Tool run_command auslösen kann.
  "commands": {
    "compile": {
      "description": "Kompiliert die C++-Module des Projekts (UnrealBuildTool).",
      "command": "C:/Program Files/Epic Games/UE_5.7/Engine/Build/BatchFiles/Build.bat",
      "args": [
        "MyGameEditor", "Win64", "Development",
        "-Project=C:/Projects/MyGame/MyGame.uproject",
        "-waitmutex", "-FromMsBuild"
      ],
      "dir": ""
    },
    "package": {
      "description": "Erstellt einen verteilbaren Windows-Build (cook + stage + pak).",
      "command": "C:/Program Files/Epic Games/UE_5.7/Engine/Build/BatchFiles/RunUAT.bat",
      "args": [
        "BuildCookRun",
        "-project=C:/Projects/MyGame/MyGame.uproject",
        "-noP4", "-platform=Win64", "-clientconfig=Development",
        "-build", "-cook", "-stage", "-pak", "-archive",
        "-archivedirectory=C:/Projects/MyGame/Packaged"
      ],
      "dir": ""
    }
  },

  "mcp": {
    "enabled": true,
    "address": "127.0.0.1:8765"
  },

  // Permission-Layer: wenn enabled, übernimmt der Launcher das Freigeben.
  //   mode "allow_all"  -> alles erlauben (außer deny-Treffer)  <- "alles freigeben"
  //   mode "allowlist"  -> nur was auf allow passt
  //   mode "deny_all"   -> alles ablehnen
  "permissions": {
    "enabled": true,
    "mode": "allow_all",
    "allow": [
      "Read", "Edit", "Write", "Bash(git *)",
      "mcp__unreagent__*"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },

  // Saubere Ausführungsumgebungen für den Agenten (run_python / run_node).
  "runtimes": {
    "python": {
      "enabled": true,
      "uv": "uv",
      "project": "",
      "prepareOnStart": true
    },
    "node": {
      "enabled": true,
      "node": "node",
      "npm": "npm",
      "project": "",
      "prepareOnStart": false
    }
  }
}
